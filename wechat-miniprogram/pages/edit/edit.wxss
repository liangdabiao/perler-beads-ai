/* edit.wxss */
.hidden-canvas {
  width: 0;
  height: 0;
  position: absolute;
  left: -9999rpx;
  top: -9999rpx;
}

.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 100rpx;
  margin: 20rpx 0;
  background-color: #FFFFFF;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.loading-icon {
  font-size: 48rpx;
  margin-right: 16rpx;
}

.loading-text {
  font-size: 32rpx;
  color: #6B7280;
}

.edit-area {
  width: 100%;
  margin: 20rpx 0;
  background-color: #FFFFFF;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  padding: 20rpx;
  overflow: auto;
}

.pixel-canvas {
  width: 100%;
  height: 400rpx;
  background-color: #F3F4F6;
  border-radius: 8rpx;
}

.color-palette {
  margin: 20rpx 0;
  background-color: #FFFFFF;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  padding: 24rpx;
}

.palette-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #4B5563;
  margin-bottom: 16rpx;
}

.color-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.color-item {
  width: 60rpx;
  height: 60rpx;
  border-radius: 8rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  cursor: pointer;
  border: 2rpx solid #E5E7EB;
}

.color-key {
  font-size: 20rpx;
  font-weight: 600;
  color: #1F2937;
  text-shadow: 0 0 2rpx rgba(255, 255, 255, 0.8);
}

.action-buttons {
  margin-top: 40rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.btn {
  width: 100%;
  padding: 20rpx;
  border-radius: 8rpx;
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
}

.btn-primary {
  background-color: #6366F1;
  color: #FFFFFF;
}

.btn-secondary {
  background-color: #FFFFFF;
  color: #6366F1;
  border: 2rpx solid #6366F1;
}